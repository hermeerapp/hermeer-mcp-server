{
  "name": "hermeer-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Hermeer — exposes HermeerSync files as tools for Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hermeer-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": ["mcp", "hermeer", "claude-desktop", "depth-companion"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hermeerapp/hermeer-mcp-server"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
